{
  "id": "pl-du-1920-152",
  "type": "statute",
  "title": "Ustawa z dnia 27 lutego 1920 r. w przedmiocie wypuszczenia pięcioprocentowej długoterminowej wewnętrznej pożyczki państwowej z r. 1920.",
  "title_en": "",
  "short_name": "pl-du-1920-152",
  "status": "in_force",
  "issued_date": "1920-02-27",
  "in_force_date": "",
  "url": "https://api.sejm.gov.pl/eli/acts/DU/1920/152",
  "provisions": [
    {
      "provision_ref": "art1",
      "section": "1",
      "title": "Art. 1",
      "content": "Upoważnia się Ministra Skarbu do wypuszczenia pięcioprocentowej wewnętrznej pożyczki państwowej z r. 1920 do sumy trzech miljardów marek polskich, ze stopniową spłatą jej w ciągu 45 lat od daty wypuszczenia według planu umorzenia, dołączonego do niniejszej ustawy."
    },
    {
      "provision_ref": "art2",
      "section": "2",
      "title": "Art. 2",
      "content": "Obligacje pięcioprocentowej wewnętrznej pożyczki państwowej z r. 1920 są wypuszczane serjami, po 20 miljonów marek każda, w odcinkach, których wysokość ustali Minister Skarbu."
    },
    {
      "provision_ref": "art3",
      "section": "3",
      "title": "Art. 3",
      "content": "Procenty od pożyczki płatne są za każde półrocze zdołu w dniach 1 kwietnia i 1 października każdego roku. Spłata umorzonych obligacji będzie dokonywana w terminach ustalonych dla opłaty procentów."
    },
    {
      "provision_ref": "art4",
      "section": "4",
      "title": "Art. 4",
      "content": "Obligacje pięcioprocentowej wewnętrznej pożyczki państwowej z r. 1920 mogą być przedstawiane do spłaty w ciągu lat 30, począwszy od dnia, ustalonego dla ich umorzenia. Kupony mogą być przedstawiane do spłaty w ciągu lat 5 od dnia ich płatności. Obligacje i kupony, nieprzedstawione do spłaty w powyższych terminach stają się nieważne."
    },
    {
      "provision_ref": "art5",
      "section": "5",
      "title": "Art. 5",
      "content": "Kupony od obligacji pięcioprocentowej wewnętrznej pożyczki państwowej z r. 1920 wolne są od podatków od kapitałów i rentowych i będą przyjmowane przy uiszczaniu podatków i opłat państwowych."
    },
    {
      "provision_ref": "art6",
      "section": "6",
      "title": "Art. 6",
      "content": "Obligacje pięcioprocentowej wewnętrznej pożyczki państwowej z r. 1920 mają wszelkie prawa papierów, posiadających bezpieczeństwo pupilarne i mogę być używane dla lokacji kapitałów osób, pozostających pod opieka i kuratelą, jakoteż kapitałów fundacyjnych, kościelnych, korporacji publicznych, kaucji cywilnych i wojskowych, depozytów oraz dla konwersji innych papierów pupilarnych."
    },
    {
      "provision_ref": "art7",
      "section": "7",
      "title": "Art. 7",
      "content": "Stopa procentowa pożyczki, wymienionej w art. 1, nie może uledz obniżeniu przed dniem 1 marca 1930 r."
    },
    {
      "provision_ref": "art8",
      "section": "8",
      "title": "Art. 8",
      "content": "Przy mającem nastąpić przerachowaniu zobowiązań, opiewających na marki polskie na przyszłą walutę polską - pięcioprocentowa wewnętrzna długoterminowa pożyczka państwowa z r. 1920 podlega przerachowaniu po kursie o 10% wyższy/n od ustalonego dla znaków obiegowych."
    },
    {
      "provision_ref": "art9",
      "section": "9",
      "title": "Art. 9",
      "content": "Pożyczka długoterminowa będzie zaliczona do pełnej wysokości przy rozkładzie zamierzonej pożyczki przymusowej rentowej."
    },
